# Windows ISO URL or local path (required)
# Get evaluation ISO from: https://www.microsoft.com/en-us/evalcenter/evaluate-windows-server
WIN_ISO_URL=

# SHA256 checksum for ISO verification (optional)
WIN_ISO_SHA256=

# Windows product key (optional — uses eval key if empty)
WIN_PRODUCT_KEY=

# Admin password (default: P@ssw0rd!)
WIN_ADMIN_PASSWORD=P@ssw0rd!

# VM hostname
WIN_HOSTNAME=WINCORE

# Timezone
WIN_TIMEZONE=UTC

# Disk size
DISK_SIZE=60G

# VM resources
RAM_MB=4096
CPU_CORES=2

# VNC display (for debugging)
VNC_DISPLAY=:0

# Host port mappings (change if defaults are in use)
HOST_RDP_PORT=13389
HOST_SSH_PORT=2222
HOST_NOVNC_PORT=16080

# Host directory shared into guest as Z:\ via virtio-fs
SHARED_DIR=

# Copy host SSH public key to guest for passwordless login (path or empty to skip)
SSH_PUBKEY=
